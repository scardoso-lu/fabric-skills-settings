# ── Target Workspace ───────────────────────────────────────────────────────
# Absolute path to the git repo agents are allowed to modify.
# Set this after cloning the target repo. Agents will never guess or default this.
TARGET_REPO_PATH=                 # e.g. /home/sco/my-fabric-project
FABRIC_WORKSPACE_PATH=            # e.g. MySandbox.Workspace (used by smoke-test-sandbox.sh)

# ── Fabric Platform ────────────────────────────────────────────────────────
FABRIC_WORKSPACE_ID=          # sandbox Fabric workspace ID
FABRIC_CAPACITY_NAME=         # capacity name (e.g., F2, P1)
PIPELINE_ENV=sandbox          # sandbox | dev | prod

# ── Lakehouse IDs (fill in after creating lakehouses) ──────────────────────
BRONZE_LAKEHOUSE_ID=
SILVER_LAKEHOUSE_ID=
GOLD_LAKEHOUSE_ID=

# ── Sandbox Data Sources ────────────────────────────────────────────────────
# Agents work with local files in data/sandbox/.
# Declare each source so the orchestrator can register it in memory/platform.md.
#
# SRC_<SYSTEM>_TYPE=file
# SRC_<SYSTEM>_PATH=./data/sandbox/<filename>.csv
#
# Examples:
# SRC_ORDERS_TYPE=file
# SRC_ORDERS_PATH=./data/sandbox/orders.csv
#
# SRC_CUSTOMERS_TYPE=file
# SRC_CUSTOMERS_PATH=./data/sandbox/customers.csv
#
# If you don't have files yet, ask the orchestrator to generate mock data.
