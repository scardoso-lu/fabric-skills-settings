# Environment
.env

# Local Claude Code overrides (machine-specific)
.claude/settings.local.json

# Data (never commit)
data/
logs/

# External skills (installed separately)
skills/external/*/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/

# Compiled notebooks
fabric_notebooks/

# Delta artifacts
_delta_log/
*.checkpoint.parquet
*.parquet

# Memory — content is local to each clone; only MEMORY.md index is shared
# Each clone generates its own memory files via setup.sh
memory/*.md
!memory/MEMORY.md
memory/runbooks/*.md
memory/security/*.md
skills/external/.registry.json

# File formats (potentially large or sensitive)
*.csv
*.xlsx
*.xls

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
settings.local.json
