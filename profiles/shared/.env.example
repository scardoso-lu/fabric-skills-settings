# Fabric Agent Pack - target repository environment template.
# Copy to .env locally if needed. Never commit .env.

# Workspace (shared by all notebooks)
FABRIC_WORKSPACE_ID=

# Lakehouses — add one entry per lakehouse referenced in any notebook sentinel
# Sentinel format in source .py:  # FABRIC_LAKEHOUSE: <NAME>
# Env-var format:                 FABRIC_LAKEHOUSE_<NAME>=<uuid>
FABRIC_LAKEHOUSE_DATALAKE=
FABRIC_LAKEHOUSE_BRONZE=
FABRIC_LAKEHOUSE_SILVER=

# Warehouses — add one entry per warehouse referenced in any notebook sentinel
# Sentinel format in source .py:  # FABRIC_WAREHOUSE: <NAME>
# Env-var format:                 FABRIC_WAREHOUSE_<NAME>=<uuid>
FABRIC_WAREHOUSE_DATA_WAREHOUSE=

# Fabric Data Warehouse TDS endpoint — from Fabric UI > DW > Settings > Connection strings
# Format: <random_prefix>.datawarehouse.fabric.microsoft.com  (NOT workspace_id based)
FABRIC_WAREHOUSE_HOST=

# Legacy (backward compat for notebooks without sentinels)
FABRIC_LAKEHOUSE_ID=
FABRIC_LAKEHOUSE_NAME=    # display name shown in the notebook UI
FABRIC_WAREHOUSE_ID=
