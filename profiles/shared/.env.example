# Fabric Agent Pack - target repository environment template.
# Copy to .env locally if needed. Never commit .env.

# Optional: embed a default lakehouse into every built notebook.
# Set to the Lakehouse item ID (not the SQL endpoint ID).

# build.py reads this and injects it into notebook-content.py so
# the lakehouse is attached on every deploy, not just the first one.
FABRIC_LAKEHOUSE_ID=
FABRIC_LAKEHOUSE_NAME=    # display name shown in the notebook UI
FABRIC_WORKSPACE_ID=