#!/usr/bin/env bash
set -euo pipefail

# Lightweight sandbox notebook/job monitor using Fabric CLI.
# It intentionally avoids direct production APIs and only wraps fab commands.
# Minimum fab version is enforced by bin/fab-sandbox (FAB_MIN_VERSION).

if [[ $# -lt 2 ]]; then
  cat >&2 <<'USAGE'
Usage:
  bin/nbmon-sandbox list <sandbox-workspace>.Workspace/<item>.<Type>
  bin/nbmon-sandbox status <sandbox-workspace>.Workspace/<item>.<Type> <job-run-id>

Examples:
  bin/nbmon-sandbox list "Sandbox.Workspace/My Notebook.Notebook"
  bin/nbmon-sandbox status "Sandbox.Workspace/My Notebook.Notebook" "<run-id>"
USAGE
  exit 2
fi

COMMAND="$1"
ITEM_PATH="$2"
shift 2

case "${COMMAND}" in
  list)
    exec "$(dirname "$0")/fab-sandbox" job run-list "${ITEM_PATH}" "$@"
    ;;
  status)
    if [[ $# -lt 1 ]]; then
      echo "status requires a job run id." >&2
      exit 2
    fi
    RUN_ID="$1"
    shift
    exec "$(dirname "$0")/fab-sandbox" job run-status "${ITEM_PATH}" "${RUN_ID}" "$@"
    ;;
  *)
    echo "Unknown command: ${COMMAND}" >&2
    exit 2
    ;;
esac
