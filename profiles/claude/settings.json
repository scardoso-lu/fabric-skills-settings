{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "effortLevel": "high",
  "skillListingBudgetFraction": 0.02,
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "high",
    "ENABLE_PROMPT_CACHING_1H": "1",
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "BASH_MAX_TIMEOUT_MS": "1800000",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_ENABLE_FEEDBACK_SURVEY_FOR_OTEL": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*secret*)",
      "Read(**/*credential*)",
      "Read(**/*token*)"
    ],
    "allow": [
      "Skill(fabric-notebook-loop)",
      "Skill(fabric-pipeline)",
      "Bash(python tool/notebook/build.py *)",
      "Bash(python3 tool/notebook/build.py *)",
      "Bash(python tool/notebook/deploy.py *)",
      "Bash(python3 tool/notebook/deploy.py *)",      
      "Bash(python tool/validate/pipeline-lineage.py *)",
      "Bash(python3 tool/validate/pipeline-lineage.py *)",
      "Bash(python tool/validate/source-contract.py *)",
      "Bash(python3 tool/validate/source-contract.py *)",
      "Bash(python tool/pipeline/manage.py *)",
      "Bash(python3 tool/pipeline/manage.py *)",
      "Bash(tool/notebook/smoke-test.sh *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git stash list)",
      "Bash(uv run bin/validate-install-package.py)",
      "Bash(uv run bin/validate-agent-guidance.py)",
      "Bash(uv run --group dev pytest)",
      "Bash(uv run --group dev pytest *)",
      "Bash(uv run tool/notebook/build.py *)",
      "Bash(uv run tool/notebook/deploy.py *)",
      "Bash(uv run tool/pipeline/manage.py *)",
      "Bash(uv run tool/validate/pipeline-lineage.py *)",
      "Bash(uv run tool/validate/source-contract.py *)",
      "Bash(uv run tool/lakehouse/list-tables.py *)",
      "Bash(python tool/lakehouse/list-tables.py *)",
      "Bash(python3 tool/lakehouse/list-tables.py *)",
      "Bash(tool/pre-commit-check.sh)",
      "Bash(bash tool/pre-commit-check.sh)",
      "Bash(fab *)",
      "Bash(rtk *)",
      "mcp__fabric__fabric_list",
      "mcp__fabric__fabric_get",
      "mcp__fabric__fabric_api_get",
      "Bash(tool/setup/fab-sandbox.ps1 --version)",
      "Bash(powershell -File tool/setup/fab-sandbox.ps1 --version)",
      "Bash(powershell -File tool/setup/fab-sandbox.ps1 api workspaces --output_format json)",
      "Bash(powershell -ExecutionPolicy Bypass -File tool/notebook/smoke-test.ps1 *)",
      "Bash(powershell -ExecutionPolicy Bypass -File tool/pre-commit-check.ps1)",
      "Bash(powershell -File tool/setup/fab-sandbox.ps1 api --help)",
      "Bash(bash tool/setup/fab-sandbox --version)",
      "Bash(bash tool/setup/fab-sandbox api workspaces --output_format json)",
      "Bash(powershell.exe -File tool/setup/fab-sandbox.ps1 --version)",
      "Bash(powershell.exe -File tool/setup/fab-sandbox.ps1 api workspaces --output_format json)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "fabric"
  ]
}
